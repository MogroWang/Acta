{
  "name": "acta",
  "version": "1.0.2-dev.0",
  "description": "Acta 行记 — notes and tasks, in one calm workspace.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "electron scripts/smoke-test.js",
    "android:sync": "cap sync android",
    "android:build": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "windows:build": "powershell -ExecutionPolicy Bypass -File scripts/package-windows.ps1"
  },
  "keywords": [
    "electron",
    "notes",
    "tasks"
  ],
  "author": "MogroWang Studio",
  "license": "MIT",
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "electron": "^37.2.3",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/status-bar": "^6.0.3"
  },
  "build": {
    "appId": "com.acta.xingji",
    "productName": "Acta 行记",
    "copyright": "Copyright © 2026 MogroWang Studio",
    "asar": true,
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis", "portable"],
      "artifactName": "Acta-${version}-${arch}-${target}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Acta 行记"
    }
  }
}
